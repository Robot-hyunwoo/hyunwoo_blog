---
import { Icon } from "astro-icon/components";
---

<!-- Fixed bottom-right "back to top" button, visible on all screen sizes -->
<div id="back-to-top-btn" class="back-to-top-btn hide fixed bottom-6 right-6 z-40 rounded-2xl overflow-hidden transition card-shadow" onclick="backToTop()">
    <button aria-label="Back to Top" class="btn-card h-12 w-12 rounded-2xl">
        <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto text-[1.75rem]"></Icon>
    </button>
</div>

<style lang="stylus">
.back-to-top-btn
    color: var(--primary)
    cursor: pointer
    opacity: 1
    transform: translateY(0)
    &.hide
        transform: translateY(1rem) scale(0.9)
        opacity: 0
        pointer-events: none
    &:active
        transform: scale(0.9)
</style>

<script is:raw is:inline>
function backToTop() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const behavior = reduce ? 'auto' : 'smooth';
    // Cover native scroll and the OverlayScrollbars-on-body case (desktop widths)
    window.scrollTo({ top: 0, behavior });
    document.documentElement.scrollTo && document.documentElement.scrollTo({ top: 0, behavior });
    document.body.scrollTo && document.body.scrollTo({ top: 0, behavior });
}
</script>
