---
import { getCollection, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";

const interests = await getCollection("interests");
// Sort by last-modified date, newest first
interests.sort((a, b) => b.data.updated.getTime() - a.data.updated.getTime());

const rendered = await Promise.all(
	interests.map(async (entry) => ({
		data: entry.data,
		Content: (await render(entry)).Content,
	})),
);
---
<MainGridLayout title="관심사" description="요즘 공부하고 관심 두는 것들">
    <div class="flex flex-col gap-4">
        <div class="card-base z-10 px-9 py-6">
            <h1 class="text-3xl font-bold text-90 mb-1">관심사</h1>
            <p class="text-50">요즘 공부하고, 관심 두고, 파고드는 것들을 기록하는 공간입니다.</p>
        </div>

        {rendered.map((item) => (
            <div class="card-base z-10 px-9 py-6">
                <div class="flex items-baseline justify-between gap-4 flex-wrap mb-2">
                    <h2 class="text-xl font-bold text-90 transition">{item.data.title}</h2>
                    <span class="text-sm text-30 transition whitespace-nowrap">
                        {formatDateToYYYYMMDD(item.data.updated)}
                    </span>
                </div>
                <Markdown class="prose-sm">
                    <item.Content />
                </Markdown>
            </div>
        ))}
    </div>
</MainGridLayout>
