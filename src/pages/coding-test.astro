---
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { url } from "../utils/url-utils";

const problems = await getCollection("problems");
// Sort by solved date, newest first
problems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// --- Contribution heatmap (binary: recorded a problem that day or not) ---
// Set of solved days as YYYY-MM-DD (UTC, matching how frontmatter dates parse)
const solvedSet = new Set(
	problems.map((p) => p.data.date.toISOString().slice(0, 10)),
);

const now = new Date();
const end = new Date(
	Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()),
);
// Start ~53 weeks back, snapped to Sunday, so we cover a full year of columns
const start = new Date(end);
start.setUTCDate(start.getUTCDate() - 7 * 52);
start.setUTCDate(start.getUTCDate() - start.getUTCDay());

interface HeatCell {
	key: string;
	filled: boolean;
	pad: boolean;
}
interface HeatWeek {
	cells: HeatCell[];
	monthLabel: string; // shown when a new month starts in this week
}
const weeks: HeatWeek[] = [];
let cur = new Date(start);
let cells: HeatCell[] = [];
let lastMonth = -1;
let weekMonthLabel = "";
const monthNames = ["1월", "2월", "3월", "4월", "5월", "6월", "7월", "8월", "9월", "10월", "11월", "12월"];
while (cur <= end) {
	const key = cur.toISOString().slice(0, 10);
	// First cell of the week decides the month label
	if (cells.length === 0) {
		const m = cur.getUTCMonth();
		weekMonthLabel = m !== lastMonth ? monthNames[m] : "";
		lastMonth = m;
	}
	cells.push({ key, filled: solvedSet.has(key), pad: false });
	if (cur.getUTCDay() === 6) {
		weeks.push({ cells, monthLabel: weekMonthLabel });
		cells = [];
	}
	cur.setUTCDate(cur.getUTCDate() + 1);
}
if (cells.length > 0) {
	while (cells.length < 7) cells.push({ key: "", filled: false, pad: true });
	weeks.push({ cells, monthLabel: weekMonthLabel });
}
const totalDays = solvedSet.size;
---
<MainGridLayout title="코딩테스트" description="백준·프로그래머스 등에서 푼 문제 기록">
    <div class="flex flex-col gap-4">
        <div class="card-base z-10 px-6 md:px-9 py-6">
            <h1 class="text-2xl md:text-3xl font-bold text-90 mb-1">코딩테스트</h1>
            <p class="text-50">백준·프로그래머스 등에서 푼 문제를 사이트·언어·알고리즘별로 기록합니다.</p>
            <span class="text-30 text-sm">총 {problems.length}문제</span>
        </div>

        <!-- Contribution heatmap -->
        <div class="card-base z-10 px-6 md:px-9 py-6">
            <div class="flex items-baseline justify-between gap-2 mb-3 flex-wrap">
                <h2 class="text-lg font-bold text-90">최근 1년 기록</h2>
                <span class="text-30 text-sm">{totalDays}일 기록</span>
            </div>
            <div class="overflow-x-auto pb-1">
                <div class="inline-flex flex-col gap-1">
                    <!-- Month labels -->
                    <div class="flex gap-[3px]">
                        {weeks.map((w) => (
                            <div class="w-3 text-[10px] text-30 leading-none h-3">{w.monthLabel}</div>
                        ))}
                    </div>
                    <!-- Week columns -->
                    <div class="flex gap-[3px]">
                        {weeks.map((w) => (
                            <div class="flex flex-col gap-[3px]">
                                {w.cells.map((c) => (
                                    c.pad ? (
                                        <div class="w-3 h-3"></div>
                                    ) : (
                                        <div
                                            class={`w-3 h-3 rounded-[2px] ${c.filled ? "bg-[var(--primary)]" : "bg-[var(--btn-regular-bg)]"}`}
                                            title={c.filled ? `${c.key} · 기록함` : c.key}
                                        ></div>
                                    )
                                ))}
                            </div>
                        ))}
                    </div>
                </div>
            </div>
            <!-- Legend -->
            <div class="flex items-center gap-2 mt-3 text-30 text-xs">
                <span>기록 없음</span>
                <div class="w-3 h-3 rounded-[2px] bg-[var(--btn-regular-bg)]"></div>
                <div class="w-3 h-3 rounded-[2px] bg-[var(--primary)]"></div>
                <span>기록함</span>
            </div>
        </div>

        {problems.length > 0 && (
            <section class="card-base z-10 px-6 md:px-9 py-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    {problems.map((p) => (
                        <a href={url(`/coding-test/${p.slug}/`)} aria-label={p.data.title}
                           class="group flex flex-col gap-2 rounded-xl px-5 py-4 bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:scale-[0.99] transition">
                            <!-- Line 1: [site] title ............ date -->
                            <div class="flex items-start justify-between gap-3">
                                <h2 class="font-bold leading-snug min-w-0">
                                    <span class="text-[var(--primary)]">[{p.data.site}]</span>
                                    <span class="text-90 group-hover:text-[var(--primary)] transition">{p.data.title}</span>
                                </h2>
                                <time class="text-30 text-xs whitespace-nowrap shrink-0 mt-1">
                                    {formatDateToYYYYMMDD(p.data.date)}
                                </time>
                            </div>

                            <!-- Line 2: source -->
                            {p.data.source && (
                                <span class="text-50 text-sm -mt-1">{p.data.source}</span>
                            )}

                            <!-- Line 3: tags -->
                            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-30 text-sm">
                                {p.data.level && <span>#{p.data.level}</span>}
                                {p.data.languages.map((lang) => <span>#{lang}</span>)}
                                {p.data.algorithms.map((algo) => <span>#{algo}</span>)}
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}

        {problems.length === 0 && (
            <div class="card-base z-10 px-9 py-12 text-center text-50">
                아직 기록된 문제가 없습니다.
            </div>
        )}
    </div>
</MainGridLayout>
